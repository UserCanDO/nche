# NCHE Environment Configuration
# Copy this file to .env and customize as needed.

# Database connection (required)
DATABASE_URL=postgres://user:password@localhost:5432/nche

# Server settings
SERVER_HOST=127.0.0.1
SERVER_PORT=3000

# Logging (optional)
# Levels: trace, debug, info, warn, error
RUST_LOG=nche=info,tower_http=info

# Executor settings (optional)
EXECUTOR_DISABLED=false
EXECUTOR_POLL_INTERVAL_MS=1000
EXECUTOR_BATCH_SIZE=10

# Webhook dispatcher settings (optional)
WEBHOOK_DISPATCHER_DISABLED=false
WEBHOOK_POLL_INTERVAL_MS=5000
WEBHOOK_BATCH_SIZE=20
WEBHOOK_MAX_RETRIES=5
